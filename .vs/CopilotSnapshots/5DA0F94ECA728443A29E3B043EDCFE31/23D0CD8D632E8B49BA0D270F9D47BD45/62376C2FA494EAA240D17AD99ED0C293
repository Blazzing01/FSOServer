using System;
using System.Collections.Generic;
using System.Text;
using Lidgren.Network;
using Spectre.Console;
using FSOServer.Packets;

namespace FSOServer.Managers
{
    public class PacketEventArgs : EventArgs
    {
        public PacketType PacketType { get; set; }
        public NetIncomingMessage Message { get; set; }
    }

    public class ServerManager
    {
        private DatabaseManager databaseManager;

        private NetPeerConfiguration _config;
        private NetServer _server;

        // Event for all packets
        public event EventHandler<PacketEventArgs> OnPacketReceived;

        // Events for specific packet types
        public event EventHandler<PacketEventArgs> OnLoginRequest;
        public event EventHandler<PacketEventArgs> OnCharacterListRequest;
        public event EventHandler<PacketEventArgs> OnMapDataRequest;
        public event EventHandler<PacketEventArgs> OnMapTransitionRequest;
        public event EventHandler<PacketEventArgs> OnCharacterMoveRequest;
        public event EventHandler<PacketEventArgs> OnInteractRequest;
        public event EventHandler<PacketEventArgs> OnAttackRequest;
        public event EventHandler<PacketEventArgs> OnWhosOnlineRequest;
        public event EventHandler<PacketEventArgs> OnFriendsOnlineRequest;
        public event EventHandler<PacketEventArgs> OnInventorySwapRequest;
        public event EventHandler<PacketEventArgs> OnInventoryDropRequest;
        public event EventHandler<PacketEventArgs> OnInventoryEquipRequest;
        public ServerManager(DatabaseManager Database)
        {
            databaseManager = Database;
        }

        public void StartServer()
        {
            AnsiConsole.MarkupLine("[green]Starting server...[/]");
            _config = new NetPeerConfiguration("networkGame") { Port = 14241 };
            _config.EnableMessageType(NetIncomingMessageType.ConnectionApproval);
            _server = new NetServer(_config);
            AnsiConsole.MarkupLine("[green]Server Started...[/]");
        }

        public void Run()
        {
            _server.Start();
            AnsiConsole.MarkupLine("[green]Server now reading messages.[/]");

            while (true)
            {
                NetIncomingMessage inc;
                if ((inc = _server.ReadMessage()) == null) continue;
                switch (inc.MessageType)
                {
                    case NetIncomingMessageType.ConnectionApproval:
                        break;
                    case NetIncomingMessageType.Data:
                        SortPacket(inc);
                        break;
                }
            }
        }

        private void SortPacket(NetIncomingMessage inc)
        {
            var packetType = (PacketType)inc.ReadByte();
        }


    }
}
